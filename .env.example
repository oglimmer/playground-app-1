# Backend configuration (consumed by backend/src/main/resources/application.yaml).
# Copy to backend/.env or export before running ./mvnw spring-boot:run if you
# want to override the built-in localhost defaults.

# --- Database ---
# docker-compose exposes Postgres on host port 5433 (see docker-compose.yml).
DB_URL=jdbc:postgresql://localhost:5433/wiki
DB_USERNAME=wiki
DB_PASSWORD=wiki

# --- Keycloak / OIDC ---
# Point these at your own Keycloak to replace the bundled docker-compose one.
OIDC_ISSUER_URI=http://localhost:8081/realms/wiki
OIDC_CLIENT_ID=wiki-app
OIDC_CLIENT_SECRET=wiki-app-secret
